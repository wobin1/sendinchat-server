{
    "info": {
        "_postman_id": "fintech-api-collection",
        "name": "SendInChat - Fintech API",
        "description": "Complete testing flow for fintech endpoints including wallet webhooks (Basic Auth)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Client Authentication",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"clientId\": \"test_client_001\",\n  \"clientSecret\": \"test_secret_001\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/fintech/auth",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "auth"
                    ]
                },
                "description": "Authenticate using client credentials. Save the access_token for subsequent requests."
            },
            "response": []
        },
        {
            "name": "2. Create Wallet",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"bvn\": \"12345678901\",\n  \"dateOfBirth\": \"1990-01-15\",\n  \"gender\": 1,\n  \"lastName\": \"Doe\",\n  \"otherNames\": \"John\",\n  \"phoneNo\": \"08012345678\",\n  \"transactionTrackingRef\": \"TRK001\",\n  \"accountName\": \"John Doe\",\n  \"placeOfBirth\": \"Lagos\",\n  \"address\": \"123 Main Street, Lagos\",\n  \"nationalIdentityNo\": \"NIN12345678\",\n  \"nextOfKinPhoneNo\": \"08087654321\",\n  \"nextOfKinName\": \"Jane Doe\",\n  \"email\": \"john.doe@example.com\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/fintech/wallet/create",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "wallet",
                        "create"
                    ]
                },
                "description": "Create a new wallet. Save the accountNo from the response for subsequent tests."
            },
            "response": []
        },
        {
            "name": "3. Credit Wallet",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"accountNo\": \"1000000001\",\n  \"narration\": \"Initial deposit\",\n  \"totalAmount\": 10000.00,\n  \"transactionId\": \"TXN001\",\n  \"merchant\": {\n    \"isFee\": false,\n    \"merchantFeeAccount\": \"\",\n    \"merchantFeeAmount\": \"0\"\n  },\n  \"transactionType\": \"deposit\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/fintech/wallet/credit",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "wallet",
                        "credit"
                    ]
                },
                "description": "Credit funds to a wallet. Use the accountNo from step 2 or the demo account."
            },
            "response": []
        },
        {
            "name": "4. Wallet Enquiry",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"accountNo\": \"1000000001\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/fintech/wallet/enquiry",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "wallet",
                        "enquiry"
                    ]
                },
                "description": "Check wallet balance and details."
            },
            "response": []
        },
        {
            "name": "5. Get Bank List",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/fintech/banks",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "banks"
                    ]
                },
                "description": "Retrieve list of all supported banks for transfers."
            },
            "response": []
        },
        {
            "name": "6. Bank Transfer",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"customer\": {\n    \"account\": {\n      \"bank\": \"058\",\n      \"name\": \"Jane Smith\",\n      \"number\": \"0123456789\",\n      \"senderaccountnumber\": \"1000000001\",\n      \"sendername\": \"Demo User\"\n    }\n  },\n  \"narration\": \"Payment for services\",\n  \"order\": {\n    \"amount\": \"5000\",\n    \"country\": \"NG\",\n    \"currency\": \"NGN\",\n    \"description\": \"Service payment\"\n  },\n  \"transaction\": {\n    \"reference\": \"REF123456\",\n    \"sessionId\": \"SESSION001\"\n  },\n  \"merchant\": {\n    \"isFee\": true,\n    \"merchantFeeAccount\": \"9999999999\",\n    \"merchantFeeAmount\": \"50\"\n  },\n  \"code\": \"00\",\n  \"message\": \"Success\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/fintech/transfer/bank",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "transfer",
                        "bank"
                    ]
                },
                "description": "Transfer funds to another bank. Ensure sender account has sufficient balance."
            },
            "response": []
        },
        {
            "name": "7. Debit Wallet",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"accountNo\": \"1000000001\",\n  \"narration\": \"Withdrawal\",\n  \"totalAmount\": 1000.00,\n  \"transactionId\": \"TXN002\",\n  \"merchant\": {\n    \"isFee\": true,\n    \"merchantFeeAccount\": \"9999999999\",\n    \"merchantFeeAmount\": \"10\"\n  },\n  \"transactionType\": \"withdrawal\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/fintech/wallet/debit",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "wallet",
                        "debit"
                    ]
                },
                "description": "Debit funds from a wallet. Ensure sufficient balance including fees."
            },
            "response": []
        },
        {
            "name": "8. Wallet Transactions",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"accountNumber\": \"1000000001\",\n  \"fromDate\": \"2025-01-01\",\n  \"toDate\": \"2025-12-31\",\n  \"numberOfItems\": \"100\"\n}"
                },
                "url": {
                    "raw": "{{base_url}}/fintech/wallet/transactions",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "fintech",
                        "wallet",
                        "transactions"
                    ]
                },
                "description": "Retrieve transaction history for a wallet within a date range."
            },
            "response": []
        },
        {
            "name": "9. Webhooks",
            "description": "Incoming wallet-provider webhooks. Requires HTTP Basic Auth using `webhook_username` and `webhook_password` collection variables (set from your `.env`). Share `/fintech/webhooks/notification` as the canonical URL with the provider.",
            "auth": {
                "type": "basic",
                "basic": [
                    {
                        "key": "username",
                        "value": "{{webhook_username}}",
                        "type": "string"
                    },
                    {
                        "key": "password",
                        "value": "{{webhook_password}}",
                        "type": "string"
                    }
                ]
            },
            "item": [
                {
                    "name": "9a. Wallet Notification (canonical)",
                    "request": {
                        "auth": {
                            "type": "basic",
                            "basic": [
                                {
                                    "key": "username",
                                    "value": "{{webhook_username}}",
                                    "type": "string"
                                },
                                {
                                    "key": "password",
                                    "value": "{{webhook_password}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"eventType\": \"inflow\",\n  \"accountNumber\": \"1000000001\",\n  \"amount\": 5000.00,\n  \"senderAccountNumber\": \"0123456789\",\n  \"senderName\": \"John Doe\",\n  \"narration\": \"Transfer from John Doe\",\n  \"transactionReference\": \"TXN-INFLOW-20260630-001\",\n  \"transactionDate\": \"2026-06-30T14:30:00Z\",\n  \"sessionId\": \"SESSION-ABC123456\",\n  \"responseCode\": \"00\",\n  \"responseMessage\": \"Successful\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/fintech/webhooks/notification",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "fintech",
                                "webhooks",
                                "notification"
                            ]
                        },
                        "description": "Canonical webhook URL to share with the wallet provider. Auto-detects inflow, upgrade-status, or raw events. Expected response: `{\"success\": true, \"status\": \"success\", \"code\": \"00\", \"message\": \"Acknowledged\"}`"
                    },
                    "response": [
                        {
                            "name": "Success - Acknowledged",
                            "originalRequest": {
                                "method": "POST",
                                "header": [
                                    {
                                        "key": "Content-Type",
                                        "value": "application/json"
                                    }
                                ],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n  \"accountNumber\": \"1000000001\",\n  \"amount\": 5000.00,\n  \"transactionReference\": \"TXN-INFLOW-20260630-001\",\n  \"transactionDate\": \"2026-06-30T14:30:00Z\"\n}"
                                },
                                "url": {
                                    "raw": "{{base_url}}/fintech/webhooks/notification",
                                    "host": [
                                        "{{base_url}}"
                                    ],
                                    "path": [
                                        "fintech",
                                        "webhooks",
                                        "notification"
                                    ]
                                }
                            },
                            "status": "OK",
                            "code": 200,
                            "_postman_previewlanguage": "json",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n  \"success\": true,\n  \"status\": \"success\",\n  \"code\": \"00\",\n  \"message\": \"Acknowledged\"\n}"
                        }
                    ]
                },
                {
                    "name": "9b. Inflow Notification",
                    "request": {
                        "auth": {
                            "type": "basic",
                            "basic": [
                                {
                                    "key": "username",
                                    "value": "{{webhook_username}}",
                                    "type": "string"
                                },
                                {
                                    "key": "password",
                                    "value": "{{webhook_password}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"accountNumber\": \"1000000001\",\n  \"amount\": 5000.00,\n  \"senderAccountNumber\": \"0123456789\",\n  \"senderName\": \"John Doe\",\n  \"narration\": \"Transfer from John Doe\",\n  \"transactionReference\": \"TXN-INFLOW-20260630-001\",\n  \"transactionDate\": \"2026-06-30T14:30:00Z\",\n  \"sessionId\": \"SESSION-ABC123456\",\n  \"responseCode\": \"00\",\n  \"responseMessage\": \"Successful\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/fintech/webhooks/inflow",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "fintech",
                                "webhooks",
                                "inflow"
                            ]
                        },
                        "description": "Dedicated inflow webhook endpoint. Same Basic Auth and acknowledgement response as the canonical notification URL."
                    },
                    "response": []
                },
                {
                    "name": "9c. Upgrade Status Notification",
                    "request": {
                        "auth": {
                            "type": "basic",
                            "basic": [
                                {
                                    "key": "username",
                                    "value": "{{webhook_username}}",
                                    "type": "string"
                                },
                                {
                                    "key": "password",
                                    "value": "{{webhook_password}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"accountNumber\": \"1000000001\",\n  \"upgradeStatus\": \"Approved\",\n  \"tier\": 2,\n  \"reason\": \"All documents verified\",\n  \"approvalDate\": \"2026-06-30T15:00:00Z\",\n  \"responseCode\": \"00\",\n  \"responseMessage\": \"Upgrade approved\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/fintech/webhooks/upgrade-status",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "fintech",
                                "webhooks",
                                "upgrade-status"
                            ]
                        },
                        "description": "Webhook for wallet tier upgrade approvals or declines. `upgradeStatus` values: Approved, Declined, Pending."
                    },
                    "response": []
                },
                {
                    "name": "9d. 9PSB Webhook (legacy alias)",
                    "request": {
                        "auth": {
                            "type": "basic",
                            "basic": [
                                {
                                    "key": "username",
                                    "value": "{{webhook_username}}",
                                    "type": "string"
                                },
                                {
                                    "key": "password",
                                    "value": "{{webhook_password}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"eventType\": \"inflow\",\n  \"accountNumber\": \"1000000001\",\n  \"amount\": 2500.00,\n  \"transactionReference\": \"9PSB-TXN-001\",\n  \"transactionDate\": \"2026-06-30T14:30:00Z\",\n  \"senderName\": \"Jane Doe\",\n  \"narration\": \"9PSB credit notification\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/fintech/webhooks/9psb",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "fintech",
                                "webhooks",
                                "9psb"
                            ]
                        },
                        "description": "Legacy alias that uses the same auth and acknowledgement contract as `/notification`."
                    },
                    "response": []
                },
                {
                    "name": "9e. Webhook - No Auth (expect 401)",
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"accountNumber\": \"1000000001\",\n  \"amount\": 5000.00,\n  \"transactionReference\": \"TXN-UNAUTH-TEST\",\n  \"transactionDate\": \"2026-06-30T14:30:00Z\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/fintech/webhooks/notification",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "fintech",
                                "webhooks",
                                "notification"
                            ]
                        },
                        "description": "Negative test: request without Basic Auth should return HTTP 401 Unauthorized."
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000",
            "type": "string"
        },
        {
            "key": "webhook_username",
            "value": "sendinchat_webhook",
            "type": "string"
        },
        {
            "key": "webhook_password",
            "value": "",
            "type": "string"
        }
    ]
}